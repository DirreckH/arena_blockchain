{
  "name": "trae-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "pnpm --filter @arena/web dev",
    "build": "pnpm --filter @arena/web build",
    "lint": "eslint .",
    "preview": "pnpm --filter @arena/web preview",
    "check": "pnpm --filter @arena/web check",
    "web:dev": "pnpm --filter @arena/web dev",
    "web:build": "pnpm --filter @arena/web build",
    "web:preview": "pnpm --filter @arena/web preview",
    "web:check": "pnpm --filter @arena/web check",
    "deps:up": "docker compose up -d postgres redis",
    "deps:down": "docker compose down",
    "validation:bootstrap:local": "node scripts/bootstrap-validation-local.cjs",
    "validation:prepare:local": "node scripts/prepare-validation-local.cjs",
    "backend:prepare:local": "node scripts/prepare-backend-local.cjs",
    "validation:env:check": "node scripts/check-validation-env.cjs",
    "validation:deps:check": "node scripts/check-validation-runtime-deps.cjs",
    "validation:chain:check": "node scripts/check-validation-contract.cjs",
    "validation:preflight": "pnpm run validation:env:check && pnpm run validation:deps:check && pnpm run validation:chain:check",
    "validation:deploy": "hardhat run scripts/deploy-validation-market.cjs",
    "validation:db:status": "node scripts/run-with-root-env.cjs apps/api pnpm run prisma:migrate:status",
    "validation:db:deploy": "node scripts/run-with-root-env.cjs apps/api pnpm run prisma:migrate:deploy",
    "validation:evidence:export": "node scripts/export-validation-rehearsal-evidence.cjs",
    "validation:evidence:capture": "node scripts/capture-validation-rehearsal-evidence.cjs",
    "validation:proof:drive": "node scripts/drive-validation-proof.cjs",
    "validation:proof:capture": "node scripts/capture-validation-proof.cjs",
    "validation:public-integrity:check": "node scripts/check-public-integrity-overview.cjs",
    "validation:public-results:check": "node scripts/check-public-settled-result.cjs",
    "backend:release:env:prepare": "node scripts/prepare-release-rehearsal-env.cjs",
    "backend:release:host:check": "node scripts/check-backend-release-host-preflight.cjs",
    "backend:release:rehearse:local": "node scripts/run-backend-release-rehearsal.cjs",
    "backend:release:repo:test": "node --test scripts/check-backend-release-readiness.test.cjs scripts/check-backend-release-repo-contract.test.cjs scripts/check-backend-release-host-preflight.test.cjs scripts/prepare-release-rehearsal-env.test.cjs scripts/run-backend-release-rehearsal.test.cjs scripts/sync-prisma-runtime-artifacts.test.cjs",
    "backend:release:repo:check": "node scripts/check-backend-release-repo-contract.cjs",
    "validation:test": "pnpm --filter @arena/api test:validation-chain",
    "api:prisma:generate": "node scripts/run-prisma-generate.cjs",
    "api:prisma:migrate": "node scripts/run-with-root-env.cjs apps/api pnpm run prisma:migrate:dev",
    "api:prisma:deploy": "node scripts/run-with-root-env.cjs apps/api pnpm run prisma:migrate:deploy",
    "api:typecheck": "pnpm run api:prisma:generate && pnpm --filter @arena/api typecheck",
    "shared:build": "pnpm --filter @arena/shared build",
    "shared:test": "pnpm --filter @arena/shared test",
    "api:build": "pnpm run api:prisma:generate && pnpm --filter @arena/api build",
    "api:dev": "pnpm --filter @arena/api dev",
    "api:start": "pnpm --filter @arena/api start:prod",
    "backend:release:check": "node scripts/check-backend-release-readiness.cjs",
    "backend:build": "pnpm --filter @arena/shared build && pnpm --filter @arena/api build",
    "ci:check": "pnpm run web:check && pnpm run shared:test && pnpm run api:typecheck && pnpm run api:build"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "ethers": "5.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@nomicfoundation/hardhat-chai-matchers": "1.0.6",
    "@nomicfoundation/hardhat-network-helpers": "1.0.8",
    "@nomicfoundation/hardhat-toolbox": "2.0.2",
    "@nomiclabs/hardhat-ethers": "2.2.3",
    "@nomiclabs/hardhat-waffle": "2.0.6",
    "@types/node": "^22.15.30",
    "chai": "^4.3.10",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "ethereum-waffle": "4.0.10",
    "globals": "^16.0.0",
    "hardhat": "2.28.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1"
  }
}
