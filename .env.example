NODE_ENV=development
ARENA_PROCESS_ROLE=all
PORT=4000

DATABASE_URL=postgresql://arena:arena@127.0.0.1:5432/arena?schema=public&connect_timeout=5
REDIS_URL=redis://127.0.0.1:6379/0

JWT_SECRET=replace-with-a-long-random-secret
AUTH_CHALLENGE_TTL=300

RPC_URL=http://127.0.0.1:8545
CHAIN_ID=1337
ARENA_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000001

# Validation-chain runtime config
ARENA_VALIDATION_ENVIRONMENT=local
ARENA_VALIDATION_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000002
ARENA_VALIDATION_SYNC_CONFIRMATIONS=1
ARENA_VALIDATION_SYNC_BATCH_SIZE=500
ARENA_VALIDATION_SYNC_POLL_INTERVAL_MS=15000

# Validation-chain signer keys used by backend command/oracle/pauser flows
ARENA_VALIDATION_OPERATOR_PRIVATE_KEY=
ARENA_VALIDATION_ORACLE_PRIVATE_KEY=
ARENA_VALIDATION_PAUSER_PRIVATE_KEY=

# Optional deployment / verification helper addresses
ARENA_VALIDATION_ADMIN_ADDRESS=
ARENA_VALIDATION_OPERATOR_ADDRESS=
ARENA_VALIDATION_ORACLE_ADDRESS=
ARENA_VALIDATION_PAUSER_ADDRESS=

# Reward payout execution config (required outside local validation env)
ARENA_REWARD_PAYOUT_ASSET_SYMBOL=USDC
ARENA_REWARD_PAYOUT_ERC20_ADDRESS=
ARENA_REWARD_PAYOUT_OPERATOR_PRIVATE_KEY=
ARENA_REWARD_PAYOUT_CONFIRMATION_COUNT=1

# Ops alert delivery config (optional; format: channel=https://target, channel:token)
ARENA_OPS_ALERT_WEBHOOK_TARGETS=
ARENA_OPS_ALERT_WEBHOOK_BEARER_TOKENS=
ARENA_OPS_ALERT_WEBHOOK_TIMEOUT_MS=5000

OPERATOR_WALLET_ADDRESSES=
ADMIN_WALLET_ADDRESSES=
SYSTEM_WALLET_ADDRESSES=
